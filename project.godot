; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format is detailed below:
; https://docs.godotengine.org/en/stable/tutorials/misc/project_settings.html

config_version=5

[application]

config/name="Gripless"
config/description="Multiplayer top-down drift-tandem racing game"
config/version="1.0.0"
run/main_scene="res://scenes/main_menu/MainMenu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

NetworkManager="*res://scripts/NetworkManager.gd"
GameState="*res://scripts/GameState.gd"
SaveGame="*res://scripts/SaveGame.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

